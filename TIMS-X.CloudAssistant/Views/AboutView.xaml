<Window x:Class="TIMS_X.CloudAssistant.Views.AboutView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TIMS_X.CloudAssistant.Views"
        mc:Ignorable="d"
        Title="About TIMS Assistant" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        MinWidth="370">
    <Window.Resources>
        <Style x:Key="PromptTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="ValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="7,2"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="5,2"></Setter>
        </Style>
        <Style x:Key="ContactTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="User:" Grid.Row="0" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding User}" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Office Code:" Grid.Row="1" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding OfficeCode}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Server Url:" Grid.Row="2" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding ServerUrl}" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Server Version:" Grid.Row="3" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding ServerVersion}" Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Client Version:" Grid.Row="4" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding Version}" Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Noah Version:" Grid.Row="5" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding NoahVersion}" Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <TextBlock Text="Noah Licensee:" Grid.Row="6" Grid.Column="0" Style="{StaticResource PromptTextStyle}"/>
        <TextBlock Text="{Binding NoahLicensee}" Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueTextStyle}"/>
        <GroupBox Header="Contact Information" Margin="0,8,0,0" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Width="312">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="Computers Unlimited" Style="{StaticResource ContactTextStyle}"/>
                <TextBlock Text="  2407 Montana Ave." Style="{StaticResource ContactTextStyle}"/>
                <TextBlock Text="   Billings, MT 59101" Style="{StaticResource ContactTextStyle}"/>
                <TextBlock Text="    1-800-763-0308" Style="{StaticResource ContactTextStyle}"/>
            </StackPanel>
        </GroupBox>

    </Grid>
</Window>
