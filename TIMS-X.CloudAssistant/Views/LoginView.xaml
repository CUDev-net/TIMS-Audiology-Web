<mah:MetroWindow x:Class="TIMS_X.CloudAssistant.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TIMS_X.CloudAssistant.Views"
        xmlns:localVMs="clr-namespace:TIMS_X.CloudAssistant.ViewModels"
        xmlns:localModels="clr-namespace:TIMS_X.CloudAssistant.Models"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:utils="clr-namespace:TIMS_X.CloudAssistant.Utils"
        xmlns:converters="clr-namespace:TIMS_X.CloudAssistant.Converters"
        md:DialogServiceViews.IsRegistered="True"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="600" Width="840"
        WindowState="Normal"
        BorderThickness="0" 
        GlowBrush="White"
        ResizeMode="CanResizeWithGrip"
        WindowTransitionsEnabled="False"
        WindowStartupLocation="CenterScreen"
        Loaded="_WindowLoaded"
        KeyDown="_HandleKeyDown">
    <mah:MetroWindow.Background>
        <ImageBrush ImageSource="../Assets/login_background.jpg"  Stretch="None"/>
    </mah:MetroWindow.Background>

    <mah:MetroWindow.Resources>
        <system:Double x:Key="SearchBoxSize">30</system:Double>
        <system:Double x:Key="PatientButtonSize">40</system:Double>
        <system:Boolean x:Key="True">True</system:Boolean>
        <system:Boolean x:Key="False">False</system:Boolean>
        <SolidColorBrush x:Key="TIMSBlue">#003768</SolidColorBrush>
        <converters:BoolVisibilityInverter x:Key="BoolVisibilityInverter" />
        <converters:InverseBooleanConverter x:Key="InvertBoolConverter" />
        <Style x:Key="TextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="33"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="White"></Setter>

            <Setter Property="Margin" Value="10,5"></Setter>
        </Style>
        <Style x:Key="PasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="33"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="White"></Setter>

            <Setter Property="Margin" Value="10,5"></Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="33"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="White"></Setter>

            <Setter Property="Margin" Value="10,5"></Setter>
        </Style>

        <Style x:Key="PromptStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,5"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Right"></Setter>
            
        </Style>
        <Style x:Key="ErrorMessageStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="20,0"></Setter>
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="LargeLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
        </Style>
        <Style x:Key="LargeLabelStyleDark" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource LargeLabelStyle}">
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style x:Key="CheckboxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

        </Style>

        <!-- Insert here your Data Templates -->
        <DataTemplate x:Key="SampleTemplate">
            <StackPanel/>
        </DataTemplate>

    </mah:MetroWindow.Resources >

    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <Grid Width="{TemplateBinding Width}"
                  Height="{TemplateBinding Height}"
                  Margin="4"
                  Background="Transparent"
                  RenderOptions.EdgeMode="Aliased"
                  RenderOptions.BitmapScalingMode="HighQuality">
                <Image Source="../Assets/timsicon2.ico"></Image>
            </Grid>
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ServerSettingsCommand}" ToolTip="Configure Server Connection" Width="30" Height="30">
                <Button.Content>
                    <Image Source="../Assets/settings.png"></Image>
                </Button.Content>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Border Background="White" CornerRadius="6" BorderThickness="2" BorderBrush="#333333" HorizontalAlignment="Center" Margin="20">
        <DockPanel>
            <StackPanel Orientation="Vertical" DockPanel.Dock="Top">
                <Image Source="../Assets/Logo.png"  Stretch="None"/>

                <Border Background="WhiteSmoke" BorderBrush="Silver" Margin="0,0,0,15"
                            CornerRadius="0" BorderThickness="0,1" HorizontalAlignment="Stretch" Height="30">
                    <TextBlock Style="{StaticResource LargeLabelStyleDark}" Text="{Binding FormHeader}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                </Border>
            </StackPanel>

            <Grid DockPanel.Dock="Top">
                <!--<Grid HorizontalAlignment="Center" x:Name="OfficeCodeForm">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="106" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PromptStyle}" Text="Office Code" Grid.Row="0" Grid.Column="0" />
                    <TextBox x:Name="OfficeCodeBox"  Style="{StaticResource TextBoxStyle}" Grid.Row="0"  Grid.Column="1" Text="{Binding OfficeCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding NextCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock x:Name="OfficeCodeErrorMessage" Visibility="Collapsed" Style="{StaticResource ErrorMessageStyle}" Grid.Row="1" Grid.Column="1" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2" Grid.Column="1" Margin="0, 30">
                        <Button  Width="120" Content="Next" Command="{Binding NextCommand}" Height="30" Margin="5,0"></Button>
                    </StackPanel>
                </Grid>-->
                <Grid HorizontalAlignment="Center" x:Name="LoginForm">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="106" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PromptStyle}" Text="User" Grid.Row="0" Grid.Column="0" />
                    <ComboBox x:Name="UserBox" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Users}" 
                              
                              SelectedItem="{Binding SelectedUser}" Grid.Row="0" Grid.Column="1" IsEnabled="{Binding UserComboEnabled}"
                              DisplayMemberPath="DisplayName" Padding="5"></ComboBox>

                    <TextBlock Style="{StaticResource PromptStyle}" Text="Site" Grid.Row="1" Grid.Column="0" />
                    <ComboBox x:Name="SiteBox" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Sites}" 
                              SelectedItem="{Binding SelectedSite}" Grid.Row="1" Grid.Column="1"
                              DisplayMemberPath="Name" Padding="5"></ComboBox>

                    <TextBlock Style="{StaticResource PromptStyle}" Text="Password" Grid.Row="2" Grid.Column="0"
                               Visibility="{Binding PasswordHidden, Converter={StaticResource BoolVisibilityInverter}, UpdateSourceTrigger=PropertyChanged}"/>
                    <PasswordBox x:Name="PasswordBox"  Style="{StaticResource PasswordBoxStyle}" Grid.Row="2" Grid.Column="1"
                                 utils:PasswordHelper.Attach="True" 
                                 utils:PasswordHelper.Password="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 mah:PasswordBoxHelper.CapsLockWarningToolTip="Warning! Caps Lock is enabled."
                                 Visibility="{Binding PasswordHidden, Converter={StaticResource BoolVisibilityInverter}, UpdateSourceTrigger=PropertyChanged}">
                        <PasswordBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LogInCommand}"/>
                        </PasswordBox.InputBindings>
                    </PasswordBox>
                    <TextBlock x:Name="PasswordErrorMessage" Visibility="Collapsed"  Style="{StaticResource ErrorMessageStyle}" Grid.Row="3" Grid.Column="1" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="4" Grid.Column="1" Margin="0, 30">
                        <Button x:Name="LogInButton" Width="120" Content="Log In" Height="30" Margin="5,0" Command="{Binding LogInCommand}"></Button>
                    </StackPanel>
                </Grid>
            </Grid>
            


        </DockPanel>
    </Border>
</mah:MetroWindow>