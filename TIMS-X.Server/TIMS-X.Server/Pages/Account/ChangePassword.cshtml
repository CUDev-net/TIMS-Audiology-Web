@page
@using System.Security.Claims
@using System.Security.Cryptography
@model Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="d-flex align-items-center flex-column justify-content-center h-100 mt-4">
    <div class="card bg-light" style="width: 28rem;">
        <div class="card-header text-center">
            @ViewData["Title"]
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="All"></div>
                <input asp-for="SupportUser.Id" type="hidden"/>
                <input asp-for="SupportUser.DateCreated" type="hidden"/>
                <input asp-for="SupportUser.Inactive" type="hidden"/>
                <input asp-for="SupportUser.Name" type="hidden"/>
                <input asp-for="SupportUser.Email" type="hidden"/>
                <div class="form-group">
                    <label asp-for="SupportUser.Name">User</label>
                    <input asp-for="SupportUser.Name" class="form-control" disabled/>
                </div>

                <div class="form-group">
                    <label asp-for="SupportUser.Password">New Password</label>
                    <input asp-for="SupportUser.Password" id="passwordField" class="form-control" onkeyup="enablePasswordChangeForm()">
                    <span asp-validation-for="SupportUser.Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SupportUser.Password">Re-enter New Password</label>
                    <input asp-for="SupportUser.Password" id="passwordRepeatField" class="form-control" onkeyup="enablePasswordChangeForm()">
                    <span asp-validation-for="SupportUser.Password" class="text-danger"></span>
                </div>
                <div class="form-group text-center">
                    <button type="submit" class="btn btn-primary" id="passwordChangeSubmit" disabled>Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>
