@page
@model Pages.Account.SignInModel
@{
    ViewData["Title"] = "Sign In";
    ViewData["PageId"] = "SignIn";
}

<div class="d-flex flex-column align-self-center">
    <img class="align-self-center img-fluid mb-2" src="~/images/logo_full_3.png" alt="logo" />
    <div class="card bg-light align-items-stretch justify-content-center login-card">
        <div class="card-header text-center">@Model.Header</div>

        @if (Model.IsOfficeCodeValid)
        {
            <div class="card-body">
                <form method="post">
                    <input asp-for="Input.ReturnUrl" type="hidden" />
                    <div class="form-group">
                        <label asp-for="Input.Username">Username</label>
                        <input asp-for="Input.Username" class="form-control">

                        @*<select asp-for="Input.UserId" class="form-control">
                @foreach (var user in Model.Users)
                {
                    <option value="@user.Id">@user.Name</option>
                }
            </select>*@
                        @*<span class="text-danger" asp-validation-for="Input.Username" class="text-danger"></span>*@
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Password">Password</label>
                        <input asp-for="Input.Password" class="form-control">
                        <span class="text-danger" asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <span class="text-danger" asp-validation-for="Input" class="text-danger"></span>
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary">Sign in</button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div id="officeCodeForm" class="card-body">
                <form method="get">
                    <input asp-for="Input.ReturnUrl" type="hidden" />
                    <div class="form-group">
                        <label asp-for="Input.OfficeCode">Office Code</label>
                        <input asp-for="Input.OfficeCode" class="form-control">
                        <span class="text-danger" asp-validation-for="Input.OfficeCode" class="text-danger"></span>
                    </div>
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary">Next</button>
                    </div>
                </form>
            </div>
        }

    </div>
</div>

@section Scripts {
<environment include="Development">
    <script src="~/js/signin.js"></script>
</environment>
<environment exclude="Development">
    <script src="~/js/signin.min.js"></script>
</environment>
        
}
