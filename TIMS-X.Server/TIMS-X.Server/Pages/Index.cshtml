@page
@using System.Security.Claims
@model TIMS_X.Server.Pages.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Home";
    ViewData["PageId"] = "Index";
}

<div class="d-flex align-items-center flex-column mt-5">
    <img class="img-fluid" src="~/images/logo_full_3.png" alt="logo" />
    <h5 class="h5">TIMS Web Server @TIMS_X.Server.Utils.VersionHelper.ServerVersion</h5>
    <h5 class="h5">Welcome, @User.FindFirstValue(ClaimTypes.Name).</h5>

</div>

