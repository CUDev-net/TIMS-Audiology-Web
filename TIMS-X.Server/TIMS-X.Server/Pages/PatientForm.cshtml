@page
@model TIMS_X.Server.Pages.PatientFormModel
@{
    ViewData["Title"] = Model.FormType;
    var allowTextNotifications = !Model.Patient.Restrictions.Any(x => x.CommunicationRestriction.Name == "No Text Notifications");
    var allowVoiceNotifications = !Model.Patient.Restrictions.Any(x => x.CommunicationRestriction.Name == "No Voice Notifications");
    var allowEmailNotifications = !Model.Patient.Restrictions.Any(x => x.CommunicationRestriction.Name == "No Email Notifications");
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
}

<div class="container mt-2">

    <h4 class="ml-2">@Model.FormTypeDesc</h4>

    <div class="form-control" id="patientForm">
        @if (Model.Form != null)
        {
            @Html.Raw(Model.Form.LiveForm)
        }
    </div>
    <div class="row mt-2">
        <div class="col text-center">
            <form method="post" id="PatientIntakeForm" asp-page-handler="PatientForm">
