                <input asp-for="IntakeData.EmplStatusId" type="hidden" id="EmplStatusId_X" />
                <input asp-for="IntakeData.Language" type="hidden" id="Language_X" />
                <input asp-for="IntakeData.Race" type="hidden" id="Race_X" />
                <input asp-for="IntakeData.Ethnicity" type="hidden" id="Ethnicity_X" />
                <input asp-for="IntakeData.Sex" type="hidden" id="Sex_X" />
                <input asp-for="IntakeData.Contact" type="hidden" id="Contact_X" />
                <input asp-for="IntakeData.ContactPhone" type="hidden" id="ContactPhone_X" />
                <input asp-for="IntakeData.EmailNotifications" type="hidden" id="EmailNotifications_X" />
                <input asp-for="IntakeData.TextNotifications" type="hidden" id="TextNotifications_X" />
                <input asp-for="IntakeData.VoiceNotifications" type="hidden" id="VoiceNotifications_X" />
                <input asp-for="IntakeData.InsCoName" type="hidden" id="InsCoName_X" />
                <input asp-for="IntakeData.InsIdNum" type="hidden" id="InsIdNum_X" />
                <input asp-for="IntakeData.InsGroupNum" type="hidden" id="InsGroupNum_X" />
                <input asp-for="IntakeData.RelationToInsured" type="hidden" id="RelationToInsured_X" />
                <input asp-for="IntakeData.InsLastName" type="hidden" id="InsLastName_X" />
                <input asp-for="IntakeData.InsInitial" type="hidden" id="InsInitial_X" />
                <input asp-for="IntakeData.InsFirstName" type="hidden" id="InsFirstName_X" />
                <input asp-for="IntakeData.InsAddress1" type="hidden" id="InsAddress1_X" />
                <input asp-for="IntakeData.InsAddress2" type="hidden" id="InsAddress2_X" />
                <input asp-for="IntakeData.InsCity" type="hidden" id="InsCity_X" />
                <input asp-for="IntakeData.InsState" type="hidden" id="InsState_X" />
                <input asp-for="IntakeData.InsZip" type="hidden" id="InsZip_X" />
                <input asp-for="IntakeData.InsPhone" type="hidden" id="InsPhone_X" />
