                <input asp-for="IntakeData.SecInsIdNum" type="hidden" id="SecInsIdNum_X" />
                <input asp-for="IntakeData.SecInsGroupNum" type="hidden" id="SecInsGroupNum_X" />
                <input asp-for="IntakeData.SecRelationToInsured" type="hidden" id="SecRelationToInsured_X" />
                <input asp-for="IntakeData.SecInsLastName" type="hidden" id="SecInsLastName_X" />
                <input asp-for="IntakeData.SecInsInitial" type="hidden" id="SecInsInitial_X" />
                <input asp-for="IntakeData.SecInsFirstName" type="hidden" id="SecInsFirstName_X" />
                <input asp-for="IntakeData.SecInsAddress1" type="hidden" id="SecInsAddress1_X" />
                <input asp-for="IntakeData.SecInsAddress2" type="hidden" id="SecInsAddress2_X" />
                <input asp-for="IntakeData.SecInsCity" type="hidden" id="SecInsCity_X" />
