                <input asp-for="IntakeData.PatientAddr2" type="hidden" id="PatientAddr2_X" />
                <input asp-for="IntakeData.PatientCity" type="hidden" id="PatientCity_X" />
                <input asp-for="IntakeData.PatientState" type="hidden" id="PatientState_X" />
                <input asp-for="IntakeData.PatientZip" type="hidden" id="PatientZip_X" />
                <input asp-for="IntakeData.ResponsibleParty" type="hidden" id="PatientRespParty_X" />
                <input asp-for="IntakeData.PatientPrimaryPhone" type="hidden" id="PatientPrimaryPhone_X" />
