                <input asp-for="IntakeData.PatientMobilePhone" type="hidden" id="PatientMobilePhone_X" />
                <input asp-for="IntakeData.PatientWorkPhone" type="hidden" id="PatientWorkPhone_X" />
                <input asp-for="IntakeData.PatientOtherPhone" type="hidden" id="PatientOtherPhone_X" />
