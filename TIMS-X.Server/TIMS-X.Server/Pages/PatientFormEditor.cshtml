@section Scripts {
    <script src="https://code.jquery.com/ui/1.13.1/jquery-ui.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
    <script src="~/js/patientformeditor.js"></script>
    @*<environment include="Development">
            <script src="~/js/patientformeditor.js"></script>
        </environment>
        <environment exclude="Development">
            <script src="~/js/patientformeditor.min.js"></script>
        </environment>*@

    <script type="text/javascript">
        $(document).ready(function () {


            var initPhone = function (id) {
                var phoneInput = window.intlTelInput(document.querySelector(id), {
                    utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js",
                    preferredCountries: ["us", "ca", "nz", "gb", "au"],
                    autoPlaceholder: false
                });

                var phoneJq = $(id)[0];

                var handleChangeVerification = function () {
                    var number = phoneInput.getNumber();
                    var newNumber = intlTelInputUtils.formatNumber(number, null, intlTelInputUtils.numberFormat.NATIONAL);
                    phoneInput.setNumber(newNumber);
                };
                phoneJq.addEventListener('change', handleChangeVerification);
                phoneJq.addEventListener('keyup', handleChangeVerification);
            }

            initPhone("#patientHomePhoneInput");
            initPhone("#patientMobilePhoneInput");
            initPhone("#patientWorkPhoneInput");
            initPhone("#patientOtherPhoneInput");
            initPhone("#contactPhoneInput");
            initPhone("#insuredPhoneInput");

            const postDataForm = document.getElementById('postDataForm');
            postDataForm.addEventListener('submit', function (e) {
                e.preventDefault();
                const postUrl = this.action;

                var editableForm = $("#currentFieldList").html();

                $("#releaseSignatureCheck").parent().parent().removeClass('mb-4');
                $("#releaseSignatureCheck").parent().parent().addClass('mt-2');

                $("#assignBenefitsCheck").parent().parent().removeClass('mb-4');
                $("#assignBenefitsCheck").parent().parent().addClass('mt-2');

                var liveForm = getFormPreview(true);

                $("#releaseSignatureCheck").parent().parent().removeClass('mt-2');
                $("#releaseSignatureCheck").parent().parent().addClass('mb-4');

                $("#assignBenefitsCheck").parent().parent().removeClass('mt-2');
                $("#assignBenefitsCheck").parent().parent().addClass('mb-4');

                //todo: this does not work
                //var formType = $('#formList :selected').val();
                var formType = 1;
                $("#FormType").val(formType);
                $("#LiveForm").val(liveForm);
                $("#EditableForm").val(editableForm);
                const formData = new FormData(this);

                fetch(postUrl, {
                    method: 'post',
                    body: formData
                }).then(function (response) {
                    if (response.status == 200) {
                        $("#infoModalHeader").text("Success");
                        $("#infoModalDescription").text("Form saved successfully.");
                        $("#infoModal").modal('show');
                    } else {
                        $("#infoModalHeader").text("Error Saving Form");
                        $("#infoModalDescription").text(response.statusText);
                        $("#infoModal").modal('show');
                    }
                    console.log(response);
                });
            });
        });

    </script>



}
