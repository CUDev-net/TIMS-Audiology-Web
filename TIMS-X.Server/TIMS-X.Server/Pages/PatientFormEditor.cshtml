@page
@model TIMS_X.Server.Pages.PatientFormEditorModel
@{
    ViewData["Title"] = "Patient Form Editor";
}

@using TIMS_X.Core.Enums;
@*@using Microsoft.AspNetCore.Antiforgery;
    @inject IAntiforgery AntiForgery;*@

@section Styles {
    <link href="~/css/patientformeditor.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
}

<svg style="display: none" version="2.0">
    <defs>
        <symbol fill="#666" color="#666" stroke="currentColor" id="custom-gripper"
                stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="feather feather-more-vertical">
            <circle cx="4" cy="5" r="2.5"></circle>
            <circle cx="4" cy="15" r="2.5"></circle>
            <circle cx="4" cy="25" r="2.5"></circle>
            <circle cx="4" cy="35" r="2.5"></circle>

            <circle cx="12" cy="5" r="2.5"></circle>
            <circle cx="12" cy="15" r="2.5"></circle>
            <circle cx="12" cy="25" r="2.5"></circle>
            <circle cx="12" cy="35" r="2.5"></circle>
        </symbol>
    </defs>
    <use href="#custom-gripper" />
</svg>

<div class="wrapper">

    @if (Model.Form.FormType == PatientFormTypeEnum.Intake)
    {
        <div class="row mt-2">
            <div class="col">
                <h4>Edit Patient Intake Form</h4>
            </div>
        </div>
        <div class="row flex-nowrap">
            <div class="col container-fluid form-control mt-2 ml-2 mr-1">
                <div class="row">
                    <div class="col-auto">
                        <h5 class="h5">Available Fields</h5>
                    </div>
                    <div class="col text-right">
                        <div class="dropdown mb-2">
                            <button class="btn btn-sm btn-outline-success dropdown-toggle" type="button" id="addFieldButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fa fa-plus"></i> Add New
                            </button>
                            <div class="dropdown-menu" aria-labelledby="addFieldButton">
                                <button type="button" class="dropdown-item" data-toggle="modal" data-target="#sectionHeaderModal">Section Header</button>
                                <button type="button" class="dropdown-item" data-toggle="modal" data-target="#checkboxModal">Checkbox</button>
                                <button type="button" class="dropdown-item" data-toggle="modal" data-target="#textModal">Text</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        @* Available Fields *@
                        <div class="list list-row card" style="min-height: 1000px; min-width: 810px;" id="availableFieldsList" data-sortable-id="0" aria-dropeffect="move">

                            @* Site Logo *@
                            <div class="list-item" id="siteLogo">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col" id="siteLogoContainer" style="max-width: 810px; overflow: hidden;">
                                    <img id="siteLogoPlaceholder" class="mx-auto d-block patFormLogo" alt="" style="object-fit: contain; padding-left: 0px;" src="@Url.Page("PatientFormEditor", "SiteLogo")" />
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#siteLogo');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#siteLogo');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="siteLogo" data-toggle="modal" data-target="#editSiteLogoModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>

                            </div>

                            @* Site Details *@
                            <div class="list-item" id="siteDetails">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col">
                                    <div class="row">
                                        <div class="col">
                                            <h4 class="text-center mb-0" id="siteName">&lt;Practice Name&gt;</h4>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <h6 class="text-center mb-0" id="siteAddr1">&lt;Address&gt;</h6>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <h6 class="text-center mb-0 hidden" id="siteAddr2"></h6>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <h6 class="text-center mb-0 hidden" id="siteCityStateZip"></h6>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <h6 class="text-center mb-0" id="sitePhone">&lt;Phone&gt;</h6>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#siteDetails');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#siteDetails');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="siteDetails" data-toggle="modal" data-target="#editSiteDetailsModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Patient Name *@
                            <div class="list-item" id="patientName">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientFirstName">Patient</label>
                                </div>
                                <div class="col-sm">
                                    <input class="form-control" id="patientFirstName" placeholder="First" maxlength="25">
                                </div>
                                <div class="col-sm-2">
                                    <input class="form-control" placeholder="MI" maxlength="1" id="patientMI">
                                </div>
                                <div class="col-sm">
                                    <input class="form-control ml-0" placeholder="Last" id="patientLastName" maxlength="35">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientName');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientName');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientName" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="list-item" id="responsibleParty">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-lg-auto">
                                    <label class="col-form-label" for="ResponsibleParty">
                                        Responsible Party
                                        <small class="text-muted">(if patient is a child, Parent or Guardian)</small>
                                    </label>
                                </div>
                                <div class="col">
                                    <input id="responsiblePartyInput" class="form-control" maxlength="50">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#responsibleParty');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#responsibleParty');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="responsibleParty" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>
                            @* Patient Address *@
                            <div class="list-item" id="patientAddress">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientAddress1">Address</label>
                                </div>
                                <div class="col">
                                    <div class="row">
                                        <div class="col">
                                            <input id="patientAddress1" class="form-control" maxlength="55" placeholder="Line 1">
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <input id="patientAddress2" class="form-control" maxlength="55" placeholder="Line 2">
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-6">
                                            <input id="patientAddressCity" class="form-control" maxlength="20" placeholder="City">
                                        </div>
                                        <div class="col-sm-auto">
                                            <select class="form-control" id="patientStateList">
                                                <option value="" disabled selected hidden="hidden">State</option>
                                                <option value="AK">AK</option>
                                                <option value="AR">AR</option>
                                                <option value="MT">MT</option>
                                            </select>
                                        </div>
                                        <div class="col">
                                            <input id="patientAddressZipCode" class="form-control" maxlength="15" placeholder="Zip Code">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-1 text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientAddress');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientAddress');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientAddress" data-toggle="modal" data-target="#editAddressModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Patient Email *@
                            <div class="list-item" id="patientEmail">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="PatientEmailAddressInput">Email</label>
                                </div>
                                <div class="col-sm">
                                    <input class="form-control" id="PatientEmailAddressInput" maxlength="99">
                                </div>

                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientEmail');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientEmail');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientEmail" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Home Phone *@
                            <div class="list-item" id="patientHomePhone">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientHomePhoneInput">Home Phone</label>
                                </div>
                                <div class="col-sm-auto">
                                    <div class="form-check m-1">
                                        <input class="form-check-input" type="radio" name="primaryPhoneGroup" id="PrimaryPhoneHome" checked>
                                        <label class="form-check-label" for="PrimaryPhoneHome">
                                            Primary
                                        </label>
                                    </div>
                                </div>
                                <div class="col">
                                    <input id="patientHomePhoneInput" class="form-control" maxlength="15" type="tel" placeholder="Home">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientHomePhone');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientHomePhone');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientHomePhone" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Mobile Phone *@
                            <div class="list-item" id="patientMobilePhone">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientMobilePhoneInput">Mobile Phone</label>
                                </div>
                                <div class="col-sm-auto">
                                    <div class="form-check m-1">
                                        <input class="form-check-input" type="radio" name="primaryPhoneGroup" id="PrimaryPhoneMobile">
                                        <label class="form-check-label" for="PrimaryPhoneMobile">
                                            Primary
                                        </label>
                                    </div>
                                </div>
                                <div class="col">
                                    <input id="patientMobilePhoneInput" class="form-control" maxlength="15" type="tel" placeholder="Mobile">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientMobilePhone');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientMobilePhone');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientMobilePhone" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Work Phone *@
                            <div class="list-item" id="patientWorkPhone">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientWorkPhoneInput">Work Phone</label>
                                </div>
                                <div class="col-sm-auto">
                                    <div class="form-check m-1">
                                        <input class="form-check-input" type="radio" name="primaryPhoneGroup" id="PrimaryPhoneWork">
                                        <label class="form-check-label" for="PrimaryPhoneWork">
                                            Primary
                                        </label>
                                    </div>
                                </div>
                                <div class="col">
                                    <input id="patientWorkPhoneInput" class="form-control" maxlength="15" type="tel" placeholder="Work">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientWorkPhone');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientWorkPhone');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientWorkPhone" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Other Phone *@
                            <div class="list-item" id="patientOtherPhone">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientOtherPhoneInput">Other Phone</label>
                                </div>
                                <div class="col-sm-auto">
                                    <div class="form-check m-1">
                                        <input class="form-check-input" type="radio" name="primaryPhoneGroup" id="PrimaryPhoneOther">
                                        <label class="form-check-label" for="PrimaryPhoneOther">
                                            Primary
                                        </label>
                                    </div>
                                </div>
                                <div class="col">
                                    <input id="patientOtherPhoneInput" class="form-control" maxlength="15" type="tel" placeholder="Other">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientOtherPhone');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientOtherPhone');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientOtherPhone" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* DOB *@
                            <div class="list-item" id="patientDOB">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="patientDtOfBirthInput">Date of Birth</label>
                                </div>
                                <div class="col">
                                    <input id="patientDtOfBirthInput" class="form-control" type="date">
                                </div>
                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#patientDOB');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#patientDOB');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="patientDOB" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>


                            @* Marital Status *@
                            <div class="list-item" id="maritalStatus">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="maritalStatusInput">Marital Status</label>
                                </div>
                                <div class="col-sm">
                                    <select class="form-control" id="maritalStatusInput">
                                        <option value=""></option>
                                    </select>
                                </div>

                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#maritalStatus');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#maritalStatus');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="maritalStatus" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>


                            @* Employment Status *@
                            <div class="list-item" id="emplStatus">
                                <div class="col-sm-auto p-0 m-0">
                                    <span class="grip-handle draggable">
                                        <svg width="16" height="40"><use href="#custom-gripper" /></svg>
                                    </span>
                                </div>
                                <div class="col-sm-2 ml-0 mr-0">
                                    <label class="col-form-label" for="emplStatusInput">Empl. Status</label>
                                </div>
                                <div class="col-sm">
                                    <select class="form-control" id="emplStatusInput">
                                        <option value=""></option>
                                    </select>
                                </div>

                                <div class="col-sm-auto text-right m-0 p-0">
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveRightBtn" title="Move field to the right" onclick="moveRight('#emplStatus');">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link pl-0 pr-0 moveLeftBtn" title="Move field to the left" onclick="moveLeft('#emplStatus');" hidden>
                                        <i class="fas fa-arrow-left"></i>
                                    </button>
                                    <button name="edit" class="btn btm-sm btn-link pl-0 pr-0" title="Edit" data-itemid="emplStatus" data-toggle="modal" data-target="#editFieldModal">
                                        <i class="fa fa-edit" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            @* Preferred Language *@
                            <div class="list-item" id="preferredLang">
