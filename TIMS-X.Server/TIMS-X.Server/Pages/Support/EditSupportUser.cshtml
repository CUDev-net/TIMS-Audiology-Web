@page "{id:int}"
@using System.Security.Claims
@model Pages.Support.EditSupportUserModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Edit Support User";
}

<h2 class="h2">@Model.SupportUser.Name</h2>
<form method="post" class="form-control" onsubmit="submitForm()">
    <div asp-validation-summary="All"></div>
    <input asp-for="SupportUser.Id" type="hidden" />
    <input asp-for="SupportUser.DateCreated" type="hidden" />
    <input asp-for="SupportUser.Password" type="hidden" />
    <div>
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="SupportUser.Inactive" />
            <label class="form-check-label" asp-for="SupportUser.Inactive"></label>
        </div>
        
        <div class="form-group">
            <label asp-for="SupportUser.Name"></label>
            <input class="form-control" asp-for="SupportUser.Name" maxlength="64" />
            <span asp-validation-for="SupportUser.Name"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="SupportUser.Email"></label>
            <input class="form-control" asp-for="SupportUser.Email" maxlength="128" />
            <span asp-validation-for="SupportUser.Email"></span>
        </div>
        @if (int.Parse(@User.FindFirstValue("User")) == Model.SupportUser.Id)
        {
            <div class="form-group">
                <a href="~/Account/ChangePassword" class="btn btn-link">Change Password</a>
            </div>
        }

    </div>

    <div>
        <button name="save" type="submit" class="btn btn-primary" onclick="submitFormClick(this)">Save</button>
        <a href="~/Support/SupportUsers" class="btn btn-dark">Cancel</a>
        
    </div>
</form>
