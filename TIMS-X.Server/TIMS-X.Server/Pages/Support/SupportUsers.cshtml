@page
@model Pages.Support.SupportUsersModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewBag.Title = "Support Users";
}
<h3 class="h3 my-auto">Support Users</h3>
<div class="container">
    <div class="row">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="col my-auto alert alert-danger m-3">
                <span>@Model.ErrorMessage</span>
            </div>

        }
        <div class="form-check my-auto m-4">
            <input type="checkbox" class="form-check-input" for="includeInactive" id="includeInactive" onchange="filterInactive()" />
            <label class="form-check-label" for="includeInactive">Include Inactive</label>
        </div>
        <div class="col my-auto ">
            <a class="btn btn-outline-success btn-sm float-right m-2" asp-page="./CreateSupportUser"><i class="fa fa-plus"></i> Add New</a>
        </div>
    </div>

    <form method="post">
        <table class="table" id="dataTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Date Created</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.SupportUsers)
                {
                    var className = user.Inactive ? "disabled" : "";
                    var styleName = user.Inactive ? "display: none" : "";
                    var disableDelete = user.CanDelete ? "" : "disabled";
                    <tr class="@className" style="@styleName">
                        <td class="@className">@user.Id</td>
                        <td class="@className"><a class="@className" asp-page="./EditSupportUser" asp-route-id="@user.Id">@user.Name</a></td>
                        <td class="@className">@user.Email</td>
                        <td class="@className">@user.DateCreated</td>
                        <td class="@className">
                            <button disabled="@user.DisableDelete" name="delete" type="submit" asp-page-handler="delete" asp-route-id="@user.Id" class="btn btn-link" onclick="return confirm('Delete user @user.Name?')" title="Delete @user.Name">
                                <i class="fa fa-trash" aria-hidden="true"></i>
                            </button>
                        </td>

                    </tr>

                }
            </tbody>
        </table>
    </form>
</div>

